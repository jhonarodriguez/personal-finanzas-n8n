# ============================================================
# Variables de entorno — Agente Personal de Finanzas
# ============================================================
# INSTRUCCIONES:
#   1. Copia este archivo: cp .env.example .env
#   2. Rellena cada valor con tus datos reales
#   3. NUNCA subas el archivo .env a GitHub
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=finanzas_user
POSTGRES_PASSWORD=CAMBIAR_POR_CONTRASEÑA_SEGURA
POSTGRES_DB=finanzas_db
POSTGRES_PORT=5432

# --- n8n ---
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# --- Autenticación del panel web de n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CAMBIAR_POR_CONTRASEÑA_SEGURA

# --- Timezone (importante para cron jobs y fechas) ---
# Lista completa: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/Bogota

# --- Telegram Bot ---
# 1. Habla con @BotFather en Telegram
# 2. Envía /newbot y sigue las instrucciones
# 3. Copia el token que te da
TELEGRAM_BOT_TOKEN=TU_TOKEN_DE_BOTFATHER_AQUI
